{
	"name": "hd-wordpress-project",
	"private": true,
	"version": "2.1.0",
	"type": "module",
	"scripts": {
		"watch:hda": "pnpm --filter hda watch",
		"build:hda": "pnpm --filter hda build",
		"watch:hdat": "pnpm --filter hdat watch",
		"build:hdat": "pnpm --filter hdat build",
		"watch:hdac": "pnpm --filter hd-ai-classic watch",
		"build:hdac": "pnpm --filter hd-ai-classic build",
		"watch:theme": "pnpm --filter spl watch",
		"build:theme": "pnpm --filter spl build",
		"watch": "pnpm -r --parallel watch",
		"build": "pnpm -r build"
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"devDependencies": {
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.0",
		"@vheemstra/vite-plugin-imagemin": "^2.2.1",
		"@wordpress/browserslist-config": "^6.47.0",
		"autoprefixer": "^10.5.0",
		"imagemin-avif": "^0.1.6",
		"imagemin-gifsicle": "^7.0.0",
		"imagemin-mozjpeg": "^10.0.0",
		"imagemin-pngquant": "^10.0.0",
		"imagemin-svgo": "^12.0.0",
		"imagemin-webp": "^8.0.0",
		"postcss": "^8.5.15",
		"sass": "^1.100.0",
		"tailwindcss": "^4.3.0",
		"terser": "^5.48.0",
		"vite": "^8.0.14",
		"vite-plugin-static-copy": "^4.1.0"
	},
	"dependencies": {
		"@lottiefiles/dotlottie-wc": "^0.9.16",
		"ensemble": "github:loltgt/ensemble",
		"ensemble-social-share": "github:loltgt/ensemble-social-share",
		"gsap": "^3.15.0",
		"nanoid": "^5.1.11",
		"photoswipe": "^5.4.4",
		"select2": "4.1.0-rc.0",
		"swiper": "^12.2.0",
		"vanilla-lazyload": "^19.1.3"
